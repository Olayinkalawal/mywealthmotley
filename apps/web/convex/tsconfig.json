{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "strictNullChecks": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "convex/*": ["../node_modules/convex/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.js"
  ],
  "exclude": ["node_modules"]
}
